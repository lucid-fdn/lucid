{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "@lucid/runtime-compat": ["packages/runtime-compat/src/index.ts"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["../node_modules", "**/*.test.ts", "**/__tests__/**"]
}
