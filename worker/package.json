{
  "name": "lucid-assistant-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Event processor for AI Assistants (Railway/Fly deployment)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm --prefix ../packages/agent-bridge run build",
    "build": "tsc",
    "start:local": "npm run build && node dist/index.js",
    "start": "node dist/railway-entrypoint.js",
    "postinstall": "node scripts/build-embedded-package.mjs",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:channels:smoke": "vitest run src/channels/slack/__tests__/SlackGatewayManager.test.ts src/channels/discord/__tests__/DiscordGatewayManager.test.ts src/channels/bridge/msteams/__tests__/outbound-delivery.test.ts src/channels/bridge/imessage/__tests__/outbound-delivery.test.ts src/__tests__/relay-inbound.test.ts",
    "e2e:nango:fixtures": "node scripts/generate-nango-e2e-fixtures.mjs",
    "e2e:nango:live": "vitest run src/agent/oauth-tools/__tests__/action-e2e.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.25",
    "@buape/carbon": "^0.0.0-beta-20260427233936",
    "@lucid-fdn/agent-tools-core": "file:../packages/agent-tools-core",
    "@lucid-fdn/code-interpreter": "file:../packages/code-interpreter",
    "@lucid-fdn/content": "file:../packages/content",
    "@lucid-fdn/plugins-embedded": "file:../packages/embedded",
    "@lucid-fdn/web3-operator": "file:../packages/web3-operator",
    "@lucid/agent-bridge": "file:../packages/agent-bridge",
    "@lucid/agent-routing": "file:../packages/agent-routing",
    "@lucid/hermes-runtime": "file:../packages/hermes-runtime",
    "@lucid/integration-auth": "file:../packages/integration-auth",
    "@lucid/openclaw-runtime": "file:../packages/openclaw-runtime",
    "@lucid/plugin-executor": "file:../packages/plugin-executor",
    "@lucid/plugin-policy": "file:../packages/plugin-policy",
    "@lucid/runtime-compat": "file:../packages/runtime-compat",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@nangohq/node": "^0.70.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.5.1",
