    "@upstash/redis": "^1.34.0",
    "@x402/evm": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "ai": "6.0.74",
    "axios": "^1.16.1",
    "bn.js": "^5.2.3",
    "bottleneck": "^2.19.5",
    "croner": "^10.0.1",
    "discord-api-types": "^0.38.40",
    "dotenv": "^17.3.1",
    "ethers": "^6.15.0",
    "express": "^4.21.0",
