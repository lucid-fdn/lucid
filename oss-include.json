{
  "version": 1,
  "defaultOutputDir": ".oss-export/LucidMerged-public",
  "include": [
    ".github/ISSUE_TEMPLATE/**",
    ".github/PULL_REQUEST_TEMPLATE.md",
    ".github/workflows/public-ci.yml",
    ".gitignore",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "Dockerfile.web",
    "LICENSE",
    "LICENSE.md",
    "LICENSING.md",
    "README.md",
    "components.json",
    "contracts/**",
    "docker/**",
    "docker-compose.full.yml",
    "docker-compose.yml",
    "docs/**",
    "eslint.config.mjs",
    "jsconfig.json",
    "migrations/**",
    "nango-integrations/**",
    "next-env.d.ts",
    "next.config.mjs",
    "oss-include.json",
    "oss-license-reviews.json",
    "package.json",
    "packages/**",
    "postcss.config.js",
    "prettier.config.js",
    "public/**",
    "railway.browser.toml",
    "railway.json",
    "railway.toml",
    "railway.web.toml",
    "railway.worker.toml",
    "sanity-typegen.json",
    "sanity.cli.ts",
    "sanity.config.ts",
    "scripts/**",
    "sentry.edge.config.ts",
    "sentry.server.config.ts",
    "src/**",
    "supabase/**",
    "tailwind.config.ts",
    "tests/**",
    "tools/**",
    "tsconfig.json",
    "vercel.json",
    "vitest.config.mts",
    "vitest.config.ts",
    "vitest.worker.config.mts",
    "worker/**"
  ],
  "exclude": [
    ".env*",
    ".github/workflows/agent-ops-quality-gates.yml",
    ".github/workflows/ci.yml",
    ".github/workflows/db-stress-test.yml",
    ".github/workflows/deploy-worker.yml",
    ".github/workflows/native-apps.yml",
    ".github/workflows/native-release.yml",
    ".github/workflows/openclaw-integration-gates.yml",
    ".github/workflows/oss-private-gates.yml",
    ".github/workflows/sync-open-source.yml",
    ".github/workflows/park-cloud-run-workers.yml",
    ".github/workflows/sync-openclaw.yml",
    ".next/**",
    ".oss-export/**",
    "apps/**",
    "assistant-detail-settings.png",
    "assistant-test-chat.png",
    "assistants-list.png",
    "coverage/**",
    "dist/**",
    "docs/generated/**",
    "docs/intel/**",
    "docs/BACKLOG.md",
    "docs/platform/native-app-architecture.md",
    "docs/platform/native-release-ops.md",
    "docs/platform/open-source-release-ops.md",
    "docs/plans/**",
    "generated/**",
    "logs/**",
    "memory-bank/**",
    "node_modules/**",
    "package-lock.json",
    "screenshots/**",
    "scripts/native-release-preflight.mjs",
    "scripts/sync-vercel-env.js",
    "skills-lock.json",
    "tsconfig.tsbuildinfo"
  ],
  "privatePaths": [
    ".github/workflows/native-apps.yml",
    ".github/workflows/native-release.yml",
    "apps/desktop/**",
    "apps/mobile/**",
    "docs/platform/native-app-architecture.md",
    "docs/platform/native-release-ops.md",
    "docs/platform/open-source-release-ops.md",
    "docs/plans/**",
    "release/signing/**"
  ],
  "requiredFiles": [
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "docs/SELF_HOSTING.md",
    "docs/ENV_REFERENCE.md",
    "docs/OPEN_SOURCE_EXPORT.md",
    "docs/PUBLIC_README.md",
    "contracts/index.ts",
    "oss-license-reviews.json",
    "package.json",
    "scripts/oss-license-audit.ts",
    "scripts/oss-smoke.ts",
    "scripts/oss-secret-scan.ts",
    "scripts/validate-public-boundary.ts",
    "scripts/export-open-source.ts"
  ],
  "textScan": {
    "ignoreFiles": [
      ".gitignore",
      "**/*.spec.ts",
      "**/*.spec.tsx",
      "**/*.test.ts",
      "**/*.test.tsx",
      "oss-include.json"
    ],
    "forbiddenLiterals": [
      "/Users/quentinbrosseau",
      "apps/mobile/.eas-secrets",
      "apps/mobile/credentials.json",
      "apps/desktop/out/make"
    ],
    "forbiddenRegex": [
      "-----BEGIN (?:RSA |EC |OPENSSH |PRIVATE )?PRIVATE KEY-----",
      "(?:EXPO_TOKEN|APPLE_API_KEY|APP_STORE_CONNECT_API_KEY|WINDOWS_SIGNING_CERT|APNS_AUTH_KEY|FCM_SERVICE_ACCOUNT)\\s*="
    ]
  },
  "packageJson": {
    "removeScriptsMatching": [
      "^(desktop|mobile|native):",
      "^env:sync"
    ],
    "removeScriptsContaining": [
      "apps/desktop",
      "apps/mobile",
      "native-release-preflight",
      "sync-vercel-env"
    ]
  }
}
