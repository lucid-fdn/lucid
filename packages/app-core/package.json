{
  "name": "@lucid/app-core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared native app route, deep-link, and platform helpers for Lucid clients",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^24",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
