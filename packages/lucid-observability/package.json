{
  "name": "@lucid/observability",
  "version": "0.1.0",
  "private": true,
  "description": "Shared observability conventions, utilities, and helpers for all Lucid services",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./conventions": {
      "types": "./dist/conventions.d.ts",
      "import": "./dist/conventions.js"
    },
    "./sentry": {
      "types": "./dist/sentry.d.ts",
      "import": "./dist/sentry.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  }
}